{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@app/(.*)$": "<rootDir>/../src/$1",
    "^@health/(.*)$": "<rootDir>/../src/health/$1",
    "^@patterns/(.*)$": "<rootDir>/../src/patterns/$1",
    "^@db/(.*)$": "<rootDir>/../src/prisma/$1",
    "^@generated/(.*)$": "<rootDir>/../generated/$1"
  }
}
