{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "node",
    "lib": ["DOM", "ESNext"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@app/*": ["src/app/*"],
      "@assets/*": ["src/assets/*"],
      "@cell/*": ["src/Cell/*"],
      "@data/*": ["src/data/*"],
      "@grid/*": ["src/Grid/*"],
      "@helpers/*": ["src/helpers/*"],
      "@infra/*": ["src/infra/*"],
      "@navigation/*": ["src/app/navigation/*"],
      "@router/*": ["src/app/router/*"],
      "@services/*": ["src/services/*"],
      "@simulation/*": ["src/app/simulation/*"],
      "@texts": ["src/texts.ts"],
      "@lib/*": ["src/lib/*"],
      "@ui/*": ["src/ui/*"],
      "@views/*": ["src/app/views/*"],
      "@conway/shared/*": ["../api-nest/src/shared/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.d.ts"]
}
