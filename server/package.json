{
  "name": "conway-gol-server",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/server.js",
  "imports": {
    "#routes/*.js": "./src/routes/*.ts",
    "#src/*.js": "./src/*.ts"
  },
  "scripts": {
    "dev": "nodemon --exec node --loader ts-node/esm src/server.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "fastify": "^5.6.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "nodemon": "^3.1.0",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.8",
    "typescript": "^5.9.3"
  }
}
