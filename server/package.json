{
  "name": "conway-gol-server",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/server.js",
  "imports": {
    "#routes/*": "./dist/routes/*",
    "#src/*": "./dist/*"
  },
  "scripts": {
    "dev": "nodemon --watch src --ext ts,json --exec tsx src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "fastify": "^5.6.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "nodemon": "^3.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
